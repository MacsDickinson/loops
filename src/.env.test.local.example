# Test Environment Variables for E2E Tests
# Copy this file to .env.test.local and fill in your test values
# See docs/clerk-test-environment-setup.md for full setup guide

# =============================================================================
# CLERK TEST ENVIRONMENT (separate from production)
# =============================================================================
# Get these from your Clerk TEST application dashboard
# https://dashboard.clerk.com → Select "Discovery Loop - Test" app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# TEST USER CREDENTIALS (for authenticated e2e flows)
# =============================================================================
# Option A: Pre-seeded test user (recommended for CI)
# Create this user in Clerk dashboard with email verification disabled
TEST_USER_EMAIL=test-user@loops-e2e.test
TEST_USER_PASSWORD=your-secure-test-password

# Option B: Dynamic test users (tests create users on-demand)
# Requires email verification disabled in Clerk test app
# No credentials needed - tests generate unique emails like test-${timestamp}@loops-e2e.test

# =============================================================================
# ANTHROPIC API (use dev/test key with low limits)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxx

# =============================================================================
# SUPABASE (can use dev database or separate test instance)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# CLERK REDIRECT URLS (defaults work for test)
# =============================================================================
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
