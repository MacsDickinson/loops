# Discovery Loop - Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# ANTHROPIC API (AI-powered loop creation)
# =============================================================================
# Where to get it: https://console.anthropic.com/settings/keys
# 1. Sign up/login at https://console.anthropic.com
# 2. Go to Settings → API Keys
# 3. Create a new API key
# Recommended: Start with $50 credit limit
ANTHROPIC_API_KEY=sk-ant-xxx

# =============================================================================
# CLERK (User Authentication)
# =============================================================================
# Where to get it: https://dashboard.clerk.com
# 1. Sign up/login at https://clerk.com
# 2. Create a new application (name: "Discovery Loop")
# 3. Copy the keys from the API Keys section
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Clerk redirect URLs (can use defaults for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# =============================================================================
# SUPABASE (Database & Backend)
# =============================================================================
# Where to get it: https://supabase.com/dashboard
# 1. Sign up/login at https://supabase.com
# 2. Create a new project (name: "discovery-loop")
# 3. Go to Settings → API
# 4. Copy the Project URL and anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# POSTHOG (Product Analytics)
# =============================================================================
# Where to get it: https://posthog.com
# 1. Sign up/login at https://posthog.com
# 2. Create a new project (name: "Discovery Loop Coach")
# 3. Go to Project Settings → Project API Key
# 4. Copy the Project API Key
# Optional: Use US cloud (https://us.i.posthog.com) or EU cloud (https://eu.i.posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# VERCEL (Optional - for deployment configuration)
# =============================================================================
# These are auto-populated by Vercel when deployed
# For local development, you can leave these blank
# VERCEL_URL=
# VERCEL_ENV=
